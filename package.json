  "main": "core/engine.js",
  "bin": {
    "aiclean": "bin/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prashant-123/aiclean.git"
  },
  "homepage": "https://aiclean.tech",
  "bugs": {
    "url": "https://github.com/Prashant-123/aiclean/issues"
  },
  "files": [
    "bin/",
    "core/",
    "adapters/",
    "config/",
    "utils/",
    "telemetry/",
    "api/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
